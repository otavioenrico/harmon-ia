# Variáveis da FUNÇÃO SERVERLESS (api/google-refresh.js) na Vercel.
# O frontend estático NÃO lê isto — ele usa assets/js/config.js.
# Configure estas no painel da Vercel (Project → Settings → Environment Variables).

# Credenciais do OAuth Client "Web" criado no Google Cloud Console.
# São as MESMAS que você cola no Supabase (Auth → Providers → Google).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Projeto Supabase — a função lê o google_refresh_token via PostgREST com o JWT
# do próprio usuário (a RLS isola a linha). URL e ANON KEY são os mesmos de config.js.
SUPABASE_URL=
SUPABASE_ANON_KEY=

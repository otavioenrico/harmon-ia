# Não existe .env em runtime: o frontend estático lê assets/js/config.js e o
# Worker lê Secrets do Cloudflare. Este arquivo é só a LISTA do que precisa
# existir em Workers → Settings → Variables and Secrets (ou `npx wrangler
# secret put NOME` um a um).

# Credenciais do OAuth Client "Web" do Google Cloud Console — as MESMAS que
# você cola no Supabase (Auth → Providers → Google). Usadas pelo Worker para
# renovar o access_token do Google (/api/google-refresh) e pelo cron de backup.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Projeto Supabase. SUPABASE_URL é var pública (já está no wrangler.jsonc);
# a anon key é a mesma de config.js. A SERVICE ROLE é SECRETA: contorna a RLS
# no cron de backup e no insert da waitlist — NUNCA vai pro frontend.
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# P0 (opcionais — recursos degradam graciosamente sem eles):
# Turnstile (anti-bot da waitlist): secret do widget criado no dashboard do
# Cloudflare. A sitekey correspondente vai nos <div class="cf-turnstile"> de
# index.html e planos.html (hoje com chave de teste que sempre passa).
TURNSTILE_SECRET=
# Resend (aviso interno de lead novo na waitlist) + e-mail que recebe o aviso.
RESEND_API_KEY=
NOTIFY_EMAIL=
